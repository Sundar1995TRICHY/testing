<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NAAC Key Indicators and Weightages</title>

<style>
    body{
        font-family: Arial, sans-serif;
        margin: 20px;
        background: #f5f7fa;
        color: #333;
    }

    h1{
        text-align:center;
        color:#004080;
    }

    table{
        width:100%;
        border-collapse:collapse;
        margin-bottom:30px;
        background:white;
        box-shadow:0 2px 5px rgba(0,0,0,0.1);
    }

    th, td{
        border:1px solid #ccc;
        padding:10px;
        text-align:center;
    }

    th{
        background:#004080;
        color:white;
    }

    .criteria{
        background:#e8f0ff;
        font-weight:bold;
    }

    .total{
        background:#d9ead3;
        font-weight:bold;
    }

    .note{
        background:#fff3cd;
        padding:15px;
        border-left:5px solid #ffc107;
    }

    @media(max-width:768px){
        table{
            display:block;
            overflow-x:auto;
        }
    }
</style>
</head>
<body>

<h1>NAAC Key Indicators and Weightages</h1>

<table>
    <tr>
        <th>Criteria</th>
        <th>Key Indicator</th>
        <th>Universities</th>
        <th>Autonomous Colleges</th>
        <th>Affiliated Colleges (UG)</th>
        <th>Affiliated Colleges (PG)</th>
    </tr>

    <!-- Criterion 1 -->
    <tr class="criteria">
        <td rowspan="5">1. Curricular Aspects</td>
        <td>1.1 Curriculum Design & Development (U)</td>
        <td>50</td><td>50</td><td>NA</td><td>NA</td>
    </tr>
    <tr>
        <td>1.1 Curricular Planning & Implementation (A)</td>
        <td>NA</td><td>NA</td><td>20</td><td>20</td>
    </tr>
    <tr>
        <td>1.2 Academic Flexibility</td>
        <td>50</td><td>40</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>1.3 Curriculum Enrichment</td>
        <td>30</td><td>40</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>1.4 Feedback System</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>
    <tr class="total">
        <td colspan="2">Total</td>
        <td>150</td><td>150</td><td>100</td><td>100</td>
    </tr>

    <!-- Criterion 2 -->
    <tr class="criteria">
        <td rowspan="7">2. Teaching-Learning & Evaluation</td>
        <td>2.1 Student Enrolment and Profile</td>
        <td>10</td><td>20</td><td>40</td><td>40</td>
    </tr>
    <tr>
        <td>2.2 Catering to Student Diversity</td>
        <td>20</td><td>30</td><td>50</td><td>50</td>
    </tr>
    <tr>
        <td>2.3 Teaching-Learning Process</td>
        <td>20</td><td>50</td><td>50</td><td>50</td>
    </tr>
    <tr>
        <td>2.4 Teacher Profile and Quality</td>
        <td>50</td><td>50</td><td>60</td><td>60</td>
    </tr>
    <tr>
        <td>2.5 Evaluation Process and Reforms</td>
        <td>40</td><td>50</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>2.6 Student Performance and Learning Outcomes</td>
        <td>30</td><td>50</td><td>60</td><td>60</td>
    </tr>
    <tr>
        <td>2.7 Student Satisfaction Survey</td>
        <td>30</td><td>50</td><td>60</td><td>60</td>
    </tr>
    <tr class="total">
        <td colspan="2">Total</td>
        <td>200</td><td>300</td><td>350</td><td>350</td>
    </tr>

    <!-- Criterion 3 -->
    <tr class="criteria">
        <td rowspan="7">3. Research, Innovations & Extension</td>
        <td>3.1 Promotion of Research and Facilities</td>
        <td>20</td><td>20</td><td>NA</td><td>NA</td>
    </tr>
    <tr>
        <td>3.2 Resource Mobilization for Research</td>
        <td>20</td><td>10</td><td>15</td><td>15</td>
    </tr>
    <tr>
        <td>3.3 Innovation Ecosystem</td>
        <td>30</td><td>10</td><td>NA</td><td>10</td>
    </tr>
    <tr>
        <td>3.4 Research Publications and Awards</td>
        <td>100</td><td>30</td><td>15</td><td>25</td>
    </tr>
    <tr>
        <td>3.5 Consultancy</td>
        <td>20</td><td>10</td><td>NA</td><td>NA</td>
    </tr>
    <tr>
        <td>3.6 Extension Activities</td>
        <td>40</td><td>50</td><td>60</td><td>50</td>
    </tr>
    <tr>
        <td>3.7 Collaboration</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>
    <tr class="total">
        <td colspan="2">Total</td>
        <td>250</td><td>150</td><td>110</td><td>120</td>
    </tr>

    <!-- Criterion 4 -->
    <tr class="criteria">
        <td rowspan="4">4. Infrastructure & Learning Resources</td>
        <td>4.1 Physical Facilities</td>
        <td>30</td><td>30</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>4.2 Library as Learning Resource</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>
    <tr>
        <td>4.3 IT Infrastructure</td>
        <td>30</td><td>30</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>4.4 Maintenance of Campus Infrastructure</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>

    <!-- Criterion 5 -->
    <tr class="criteria">
        <td rowspan="4">5. Student Support & Progression</td>
        <td>5.1 Student Support</td>
        <td>30</td><td>30</td><td>50</td><td>50</td>
    </tr>
    <tr>
        <td>5.2 Student Progression</td>
        <td>40</td><td>30</td><td>30</td><td>25</td>
    </tr>
    <tr>
        <td>5.3 Student Participation and Activities</td>
        <td>20</td><td>30</td><td>50</td><td>45</td>
    </tr>
    <tr>
        <td>5.4 Alumni Engagement</td>
        <td>10</td><td>10</td><td>10</td><td>10</td>
    </tr>

    <!-- Criterion 6 -->
    <tr class="criteria">
        <td rowspan="5">6. Governance, Leadership & Management</td>
        <td>6.1 Institutional Vision and Leadership</td>
        <td>10</td><td>10</td><td>10</td><td>10</td>
    </tr>
    <tr>
        <td>6.2 Strategy Development and Deployment</td>
        <td>10</td><td>10</td><td>10</td><td>10</td>
    </tr>
    <tr>
        <td>6.3 Faculty Empowerment Strategies</td>
        <td>30</td><td>30</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>6.4 Financial Management & Resource Mobilization</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>
    <tr>
        <td>6.5 Internal Quality Assurance System</td>
        <td>30</td><td>30</td><td>30</td><td>30</td>
    </tr>

    <!-- Criterion 7 -->
    <tr class="criteria">
        <td rowspan="3">7. Institutional Values & Best Practices</td>
        <td>7.1 Institutional Values and Social Responsibilities</td>
        <td>50</td><td>50</td><td>50</td><td>50</td>
    </tr>
    <tr>
        <td>7.2 Best Practices</td>
        <td>30</td><td>30</td><td>30</td><td>30</td>
    </tr>
    <tr>
        <td>7.3 Institutional Distinctiveness</td>
        <td>20</td><td>20</td><td>20</td><td>20</td>
    </tr>
</table>

<div class="note">
    <strong>Notes:</strong>
    <ul>
        <li>(U) Applicable only for Universities and Autonomous Colleges.</li>
        <li>(A) Applicable only for Affiliated / Constituent Colleges.</li>
        <li>NA = Not Applicable.</li>
        <li>Total Score = 1000 (subject to NAAC applicable metrics).</li>
    </ul>
</div>

</body>
</html>
